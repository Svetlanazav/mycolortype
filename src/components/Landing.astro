<CommentSection />

<!-- FAQ -->
<section class="py-16 px-4 bg-white">
  <div class="container mx-auto max-w-2xl">
    <div class="text-center mb-10">
      <h2 class="text-3xl md:text-4xl font-bold text-primary-plum mb-3">Common questions</h2>
      <p class="text-primary-mauve text-base md:text-lg">Everything you need to know before you start.</p>
    </div>
    <div class="faq-list">

      <details class="faq-item">
        <summary class="faq-question">
          What is color season analysis?
          <span class="faq-chevron" aria-hidden="true">+</span>
        </summary>
        <p class="faq-answer">
          Color season analysis identifies which of 12 seasonal palettes (Spring, Summer, Autumn, Winter — each with sub-types) best matches your natural coloring. Wearing your season's colors makes you look more radiant and put-together.
        </p>
      </details>

      <details class="faq-item">
        <summary class="faq-question">
          What kind of photo works best?
          <span class="faq-chevron" aria-hidden="true">+</span>
        </summary>
        <p class="faq-answer">
          A clear selfie in natural daylight works best. Make sure your face and hair are fully visible, avoid heavy filters or artificial light. No make-up gives the most accurate result.
        </p>
      </details>

      <details class="faq-item">
        <summary class="faq-question">
          Is my photo stored or shared?
          <span class="faq-chevron" aria-hidden="true">+</span>
        </summary>
        <p class="faq-answer">
          No. Your photo is processed entirely in your browser — it never leaves your device and is never uploaded to any server. Your privacy is fully protected.
        </p>
      </details>

      <details class="faq-item">
        <summary class="faq-question">
          How accurate is the AI analysis?
          <span class="faq-chevron" aria-hidden="true">+</span>
        </summary>
        <p class="faq-answer">
          Our AI uses MediaPipe face detection to extract your skin, hair, and eye colors, then maps them to seasonal characteristics. A confidence score is shown with every result. Natural lighting gives the best accuracy.
        </p>
      </details>

      <details class="faq-item">
        <summary class="faq-question">
          Can I use it on my phone?
          <span class="faq-chevron" aria-hidden="true">+</span>
        </summary>
        <p class="faq-answer">
          Yes! MyColorType works fully in your mobile browser. Upload from your gallery or use your camera directly — no app needed.
        </p>
      </details>

    </div>
  </div>
</section>

<!-- CTA -->
<section class="py-16 px-4 bg-linear-to-r from-primary-sand to-white">
