---
import ImageUploadContainer from "../components/ImageUploadContainer";
import CommentSection from "../components/Comments.astro";
---

<!-- Header -->
<header class="bg-primary-plum text-white py-4">
  <div class="container mx-auto flex justify-between items-center px-4">
    <h1 class="text-2xl font-bold">MyColorType</h1>
    <nav>
      <button class="md:hidden bg-primary-mauve p-2 rounded">Menu</button>
      <ul class="hidden md:flex space-x-5 font-medium lg:space-x-10">
        <li>
          <a href="#startanalysis" class="hover:text-accent-gold"
            >How to start</a
          >
        </li>
        <li>
          <a href="#coloranalysis" class="hover:text-accent-gold"
            >Color Analysis</a
          >
        </li>
        <li><a href="#features" class="hover:text-accent-gold">Features</a></li>
        <li>
          <a href="/mycolortype/blog" class="hover:text-accent-gold">Blog</a>
        </li>
        <li>
          <a href="#testimonials" class="hover:text-accent-gold">Reviews</a>
        </li>
      </ul>
    </nav>
    <a
      href="#imageupload"
      class="hidden md:inline-block px-5 py-2 text-white rounded-full text-lg transition-colors bg-linear-to-r from-accent-gold to-primary-plum hover:from-primary-mauve hover:to-primary-plum"
    >
      Get Started
    </a>
  </div>
</header>

<!-- Hero Section -->
<div class="bg-linear-to-r from-primary-sand to-white">
  <section
    class="container mx-auto px-6 py-12 relative overflow-hidden md:overflow-visible"
  >
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <!-- Left Column -->
      <div
        class="space-y-6 pb-5 pt-2 sm:pb-8 sm:pt-24 md:pb-8 md:pt-8 relative z-10 hero-animate"
      >
        <!-- Trust badges -->
        <div class="flex flex-wrap gap-2">
          <span class="hero-badge">✓ Free</span>
          <span class="hero-badge">✓ AI-powered</span>
          <span class="hero-badge">✓ Instant results</span>
        </div>

        <h1
          class="font-display text-balance text-5xl/[0.9] font-normal tracking-tight text-primary-plum md:text-6xl/[0.9] lg:text-8xl/[0.9]"
        >
          Discover Your<br />
          Perfect<br />
          Color Palette
        </h1>
        <p class="text-primary-mauve text-lg max-w-md lg:text-2xl text-pretty">
          Transform your style with professional color analysis. Learn which
          colors make you look and feel your absolute best.
        </p>
        <a
          href="#imageupload"
          class="block sm:inline-block text-center px-7 py-4 text-white rounded-full text-lg font-semibold transition-colors bg-linear-to-r from-accent-gold to-primary-plum hover:from-primary-mauve hover:to-primary-plum"
          >GET STARTED</a
        >
      </div>
      <!-- Right Column - Image (bg on mobile) -->
      <!-- Mobile version -->
      <div class="absolute inset-0 block md:hidden z-0">
        <img
          src="/mycolortype/pics/AI_color.jpg"
          alt="Color Palette Illustration"
          class="absolute inset-0 h-auto transform scale-x-[-1] translate-x-1/2 opacity-50 m-auto"
        />
      </div>
      <!-- Desktop version -->
      <div class="hidden md:block">
        <img
          src="/mycolortype/pics/AI_color.jpg"
          alt="Color Palette Illustration"
          class="w-full h-auto rounded-3xl"
        />
      </div>
    </div>
  </section>
</div>
<!-- Custom shape divider -->
<div class="custom-shape-divider-top-1735495376">
