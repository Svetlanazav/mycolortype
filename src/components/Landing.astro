    <p class="text-primary-mauve text-base md:text-lg mb-12 max-w-2xl mx-auto">
      Analyze colors that define you, your personality and your style.
    </p>
    <div class="grid md:grid-cols-3 gap-8 text-left max-w-3xl mx-auto">

      <!-- Step 1 -->
      <div class="bg-primary-sand rounded-lg p-6 shadow-sm transition-transform hover:scale-105">
        <div class="flex items-center gap-3 mb-4">
          <div class="step-icon-wrap">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 0 1 5.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 0 0-1.134-.175 2.31 2.31 0 0 1-1.64-1.055l-.822-1.316a2.192 2.192 0 0 0-1.736-1.039 48.774 48.774 0 0 0-5.232 0 2.192 2.192 0 0 0-1.736 1.039l-.821 1.316Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 1 1-9 0 4.5 4.5 0 0 1 9 0Z" />
            </svg>
          </div>
          <span class="text-accent-gold font-bold text-sm uppercase tracking-widest">Step 1</span>
        </div>
        <h3 class="font-semibold text-primary-plum mb-2">Take your photo</h3>
        <p class="text-primary-mauve text-sm leading-relaxed">
          A clear selfie in natural light works best. Make sure your face and hair are fully visible.
        </p>
      </div>

      <!-- Step 2 -->
      <div class="bg-primary-sand rounded-lg p-6 shadow-sm transition-transform hover:scale-105">
        <div class="flex items-center gap-3 mb-4">
          <div class="step-icon-wrap">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
