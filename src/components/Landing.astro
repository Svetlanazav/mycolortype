<!-- Steps section -->
<section
  id="startanalysis"
  class="bg-linear-to-r from-primary-sand to-white text-center py-16 px-4 relative"
>
  <div class="container mx-auto max-w-4xl">
    <h2 class="text-3xl md:text-4xl font-bold text-primary-plum mb-4">
      Colors are powerful—let’s find the ones that empower you
